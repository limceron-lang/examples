// 08 — Taint Types
// Demonstrates Limceron's taint tracking system for preventing prompt injection.
// Data is tagged with provenance labels that the compiler tracks through the program.
// Compare with: ../markdown/08_taint_types.lceron.md

capability llm {
    complete
}

capability web {
    fetch
}

// Taint declarations: mark data provenance
taint user_input       // Data from external users — untrusted
taint llm_output       // Data generated by the LLM — semi-trusted
taint sanitized        // Data that has passed through a guard — trusted

budget TaintBudget {
    max_tokens: 5000
    max_cost: 0.50
    max_duration: 30
}

// Guard that sanitizes user input before it reaches the LLM
guard sanitize_input(text: string) {
    let max_length = 5000
    let strip_html = true
}

// Guard that validates LLM output before it reaches external tools
guard validate_output(text: string) {
    let no_code_execution = true
    let no_urls = false
}

// Tool that requires sanitized input (compiler enforces taint flow)
tool summarize(text: string) -> Result {
    requires: [llm.complete]
    description: "Summarize text — input must be sanitized (not raw user_input)"
}

// Tool that requires validated output (won't accept raw llm_output)
tool publish(text: string) -> Result {
    requires: [web.fetch]
    description: "Publish text externally — output must be validated"
}

agent TaintDemo {
    capabilities: [llm.complete, web.fetch]
    model: "llama3"
    budget: TaintBudget
    prompt: "You demonstrate taint tracking.\nData carries provenance labels: user_input -> sanitized -> llm_output -> validated.\nThe compiler enforces these flows at build time."

    fn process(raw_input: string) -> Result {
        // raw_input is tainted as user_input
        // summarize() requires sanitized input
        // The compiler ensures sanitize_input() runs first
        let clean = raw_input
        let summary = summarize(clean)
        summary
    }
}

fn main() -> Result {
    let agent = TaintDemo
    let result = agent.process("Please summarize this article about AI safety")
    result
}
